+static void cmd_ntp_clock_sync(void *p) {
+    struct mp_cmd_ctx *cmd = p;
+    struct MPContext *mpctx = cmd->mpctx;
+    double ntp_time = cmd->args[0].v.d;
+    int64_t svr_time = cmd->args[1].v.i64;
+    int64_t now_ms = mp_sys_time_us() / 1000;
+    int64_t diff = now_ms - svr_time;
+    MP_VERBOSE(mpctx, "[cmd_ntp_clock_sync]: ntp-time:%.3f, svr-time:%lld diff:%lldms\n", ntp_time, (long long)svr_time, diff);
+    mp_ntp_clock_set_time(&mpctx->ntp_clock, (ntp_time + diff) / 1000.0);
+}
+
+static void cmd_ntp_timecode(void *p) {
+    struct mp_cmd_ctx *cmd = p;
+    struct MPContext *mpctx = cmd->mpctx;
+    mp_ntp_clock_set_timecode(&mpctx->ntp_clock,
+        cmd->args[0].v.d / 1000.0, cmd->args[1].v.d, cmd->args[2].v.b);
+}
+

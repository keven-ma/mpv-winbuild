+            {"svr-time", OPT_INT64(v.i64)},
+        },
+    },
+    { "ntp-timecode", cmd_ntp_timecode,
+        {
+            {"ntp-time", OPT_DOUBLE(v.d)},
+            {"timecode", OPT_DOUBLE(v.d)},
+            {"paused", OPT_BOOL(v.b)},
+        },
+    },
+
     { "ignore", cmd_ignore, .is_ignore = true, .is_noisy = true, },
 
     { "seek", cmd_seek,

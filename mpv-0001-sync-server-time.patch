+static void handle_server_pause(struct MPContext *mpctx) {
+    if (!mpctx->vo_chain || !mpctx->vo_chain->vo)
+        return;
+    if (mpctx->vo_chain->vo->opts->video_sync != VS_TIMECODE)
+        return;
+
+    struct mp_ntp_clock *sc = &mpctx->ntp_clock;
+    bool ntp_paused = mp_ntp_clock_is_paused(sc);
+    bool user_paused   = mpctx->opts->pause;
+
+    if (ntp_paused == user_paused)
+        return;
+
+    if (ntp_paused) {
+        // Server requested pause: seek precisely to the target timecode first,
+        // then pause.  set_pause_state(true) sets opts->pause = true so the
+        // next call won't re-enter this branch.
+        double target_tc = mp_ntp_clock_get_target_timecode(sc);
+        if (target_tc != MP_NOPTS_VALUE) {
+            queue_seek(mpctx, MPSEEK_ABSOLUTE, target_tc, MPSEEK_EXACT, 0);
+            
+            // Clean up PID and local speed residuals because this preempts write_video
+            mp_ntp_clock_reset_pid(sc);
+            if (mpctx->speed_factor_v != 1.0 || mpctx->speed_factor_a != 1.0) {
+                mpctx->speed_factor_v = 1.0;
+                mpctx->speed_factor_a = 1.0;
+                update_playback_speed(mpctx);
+            }
+        }
+        set_pause_state(mpctx, true);
+    } else {
+        // Server resumed: lift the pause we set.
+        set_pause_state(mpctx, false);
+    }
+}
+
 void run_playloop(struct MPContext *mpctx)
 {
+    handle_server_pause(mpctx);
+
     if (encode_lavc_didfail(mpctx->encode_lavc_ctx)) {
         mpctx->stop_play = PT_ERROR;
         return;
diff --git a/player/server_sync.c b/player/server_sync.c
new file mode 100644
index 0000000000..42947a9dbe
--- /dev/null
+++ b/player/server_sync.c
@@ -0,0 +1,236 @@
+#include "server_sync.h"
+#include <math.h>
+
+void mp_ntp_clock_init(struct mp_ntp_clock *sc) {
+    atomic_init(&sc->clock_valid, false);
+    atomic_init(&sc->local_time_ns, 0);
+    atomic_init(&sc->ntp_time_us, 0);
+
+    atomic_init(&sc->tc_gen, 0);
+    atomic_init(&sc->timecode_valid, false);
+    atomic_init(&sc->tc_ntp_time_us, 0);
+    atomic_init(&sc->tc_timecode_us, 0);
+    atomic_init(&sc->tc_paused, false);
+
+    atomic_init(&sc->stat_is_correcting, false);
+    atomic_init(&sc->stat_frames_total, 0);
+    atomic_init(&sc->stat_frames_diff_17, 0);
+    atomic_init(&sc->stat_frames_diff_35, 0);
+    atomic_init(&sc->stat_frames_diff_50, 0);
+    atomic_init(&sc->stat_frames_diff_68, 0);
+
+    atomic_init(&sc->vpts_seq, 0);
+    atomic_init(&sc->vpts_server_us, 0);
+    atomic_init(&sc->vpts_pts_us, 0);
+    atomic_init(&sc->vpts_paused, 0);
+
+    sc->pid_integral      = 0.0;
+    sc->pid_last_diff     = 0.0;
+    sc->pid_last_speed    = 1.0;
+    sc->pid_is_correcting = false;
+}
+
+void mp_ntp_clock_set_time(struct mp_ntp_clock *sc, double ntp_time) {
+    atomic_store(&sc->local_time_ns, mp_time_ns());
+    atomic_store(&sc->ntp_time_us, (int64_t)(ntp_time * 1000000.0));
+    atomic_store(&sc->clock_valid, true);
+}
+
+double mp_ntp_clock_get_ntp_time(struct mp_ntp_clock *sc) {
+    if (!atomic_load(&sc->clock_valid))
+        return MP_NOPTS_VALUE;
+    int64_t local_elapsed = mp_time_ns() - atomic_load(&sc->local_time_ns);
+    double server_base = atomic_load(&sc->ntp_time_us) / 1000000.0;
+    return server_base + local_elapsed / 1000000000.0;
+}
+
+// Seqlock-protected write.  The reader in mp_ntp_clock_get_target_timecode
+// spins if it sees an odd generation, and retries if it sees a generation
+// change between its two reads.  This guarantees the reader always sees a
+// consistent (ntp_time, timecode, paused) triple.
+void mp_ntp_clock_set_timecode(struct mp_ntp_clock *sc, double ntp_time,
+                                   double timecode, bool paused)
+{
+    // ── begin write: bump generation to odd ──
+    uint32_t gen = atomic_load_explicit(&sc->tc_gen, memory_order_relaxed);
+    uint32_t next_odd = (gen | 1u);
+    atomic_store_explicit(&sc->tc_gen, next_odd, memory_order_relaxed);
+    atomic_thread_fence(memory_order_release);
+
+    atomic_store_explicit(&sc->tc_ntp_time_us,
+                          (int64_t)(ntp_time * 1000000.0),
+                          memory_order_relaxed);
+    atomic_store_explicit(&sc->tc_timecode_us,
+                          (int64_t)(timecode   * 1000000.0),
+                          memory_order_relaxed);
+    atomic_store_explicit(&sc->tc_paused, paused, memory_order_relaxed);
+
+    // ── end write: bump generation to even ──
+    atomic_thread_fence(memory_order_release);
+    atomic_store_explicit(&sc->tc_gen, next_odd + 1u, memory_order_relaxed);
+
+    // Mark valid only after payload is complete.
+    atomic_store(&sc->timecode_valid, true);
+}
+
+// Seqlock-protected read.  Retries until it catches a stable even generation.
+double mp_ntp_clock_get_target_timecode(struct mp_ntp_clock *sc) {
+    if (!atomic_load(&sc->clock_valid))
+        return MP_NOPTS_VALUE;
+
+    int64_t tc_us, st_us;
+    bool paused;
+
+    for (;;) {
+        uint32_t g1 = atomic_load_explicit(&sc->tc_gen, memory_order_acquire);
+        if (g1 & 1u)
+            continue;  // write in progress, spin
+
+        if (!atomic_load_explicit(&sc->timecode_valid, memory_order_relaxed))
+            return MP_NOPTS_VALUE;
+
+        tc_us  = atomic_load_explicit(&sc->tc_timecode_us,    memory_order_relaxed);
+        st_us  = atomic_load_explicit(&sc->tc_ntp_time_us, memory_order_relaxed);
+        paused = atomic_load_explicit(&sc->tc_paused,         memory_order_relaxed);
+
+        atomic_thread_fence(memory_order_acquire);
+        uint32_t g2 = atomic_load_explicit(&sc->tc_gen, memory_order_relaxed);
+        if (g1 == g2)
+            break;  // consistent snapshot obtained
+    }
+
+    double tc = tc_us / 1000000.0;
+    if (paused)
+        return tc;  // frozen at reported position
+
+    double tc_st   = st_us / 1000000.0;
+    double now_st  = mp_ntp_clock_get_ntp_time(sc);
+    return tc + (now_st - tc_st);
+}
+
+bool mp_ntp_clock_is_paused(struct mp_ntp_clock *sc) {
+    if (!atomic_load(&sc->timecode_valid))
+        return false;
+    return atomic_load(&sc->tc_paused);
+}
+
+void mp_ntp_clock_add_stat(struct mp_ntp_clock *sc, double abs_diff, bool is_correcting) {
+    atomic_store(&sc->stat_is_correcting, is_correcting);
+    atomic_fetch_add(&sc->stat_frames_total, 1);
+    if (abs_diff < 0.017) atomic_fetch_add(&sc->stat_frames_diff_17, 1);
+    if (abs_diff < 0.035) atomic_fetch_add(&sc->stat_frames_diff_35, 1);
+    if (abs_diff < 0.050) atomic_fetch_add(&sc->stat_frames_diff_50, 1);
+    if (abs_diff < 0.068) atomic_fetch_add(&sc->stat_frames_diff_68, 1);
+}
+
+// Reset PID controller state.  Call after any seek or restart so that stale
+// integral / derivative history does not pollute the new playback segment.
+void mp_ntp_clock_reset_pid(struct mp_ntp_clock *sc) {
+    sc->pid_integral      = 0.0;
+    sc->pid_last_diff     = 0.0;
+    sc->pid_last_speed    = 1.0;
+    sc->pid_is_correcting = false;
+}
+
+// Full reset: wipes all runtime state so the next playback session starts clean.
+// Clears NTP validity, timecode validity, statistics, vpts snapshot, and PID.
+// The struct itself stays allocated — call init() only once at process startup.
+void mp_ntp_clock_reset(struct mp_ntp_clock *sc) {
+    // NTP sync
+    atomic_store(&sc->clock_valid, false);
+    atomic_store(&sc->local_time_ns, 0);
+    atomic_store(&sc->ntp_time_us, 0);
+
+    // Timecode seqlock payload — bump tc_gen to an even value so readers see
+    // a stable (but invalid) generation, then clear timecode_valid.
+    atomic_store_explicit(&sc->tc_gen, 0, memory_order_relaxed);
+    atomic_store(&sc->timecode_valid, false);
+    atomic_store(&sc->tc_ntp_time_us, 0);
+    atomic_store(&sc->tc_timecode_us, 0);
+    atomic_store(&sc->tc_paused, false);
+
+    // Statistics
+    atomic_store(&sc->stat_is_correcting, false);
+    atomic_store(&sc->stat_frames_total, 0);
+    atomic_store(&sc->stat_frames_diff_17, 0);
+    atomic_store(&sc->stat_frames_diff_35, 0);
+    atomic_store(&sc->stat_frames_diff_50, 0);
+    atomic_store(&sc->stat_frames_diff_68, 0);
+
+    // vpts seqlock snapshot — reset to "never committed" (seq = 0)
+    atomic_store_explicit(&sc->vpts_seq, 0, memory_order_relaxed);
+    atomic_store_explicit(&sc->vpts_server_us, 0, memory_order_relaxed);
+    atomic_store_explicit(&sc->vpts_pts_us, 0, memory_order_relaxed);
+    atomic_store_explicit(&sc->vpts_paused, 0, memory_order_relaxed);
+
+    // PID controller
+    mp_ntp_clock_reset_pid(sc);
+}
+
+// Seqlock writer: called from the playback thread (single writer).
+// Writes an atomic (ntp_time, video_pts, is_paused) snapshot.
+void mp_ntp_clock_commit_video_pts(struct mp_ntp_clock *sc,
+                                       double ntp_time, double video_pts,
+                                       bool is_paused)
+{
+    if (!atomic_load(&sc->clock_valid))
+        return;
+
+    // Step 1: mark write-in-progress by setting seq to odd.
+    uint64_t seq = atomic_load_explicit(&sc->vpts_seq, memory_order_relaxed);
+    atomic_store_explicit(&sc->vpts_seq, seq | 1, memory_order_relaxed);
+
+    // Step 2: release fence ensures the "odd" marker is visible before
+    // the payload writes below.
+    atomic_thread_fence(memory_order_release);
+
+    atomic_store_explicit(&sc->vpts_server_us,
+                          (int64_t)(ntp_time * 1000000.0),
+                          memory_order_relaxed);
+    atomic_store_explicit(&sc->vpts_pts_us,
+                          (int64_t)(video_pts   * 1000000.0),
+                          memory_order_relaxed);
+    atomic_store_explicit(&sc->vpts_paused,
+                          (int32_t)is_paused,
+                          memory_order_relaxed);
+
+    // Step 3: release fence then advance seq to next even value, signalling
+    // readers that the payload is complete.
+    atomic_thread_fence(memory_order_release);
+    atomic_store_explicit(&sc->vpts_seq, (seq | 1) + 1, memory_order_relaxed);
+}
+
+// Seqlock reader: safe to call from any thread.
+bool mp_ntp_clock_get_video_pts(struct mp_ntp_clock *sc,
+                                    double *out_ntp_time,
+                                    double *out_video_pts,
+                                    bool   *out_is_paused)
+{
+    for (;;) {
+        // Acquire-load ensures we see the latest seq before reading payload.
+        uint64_t seq1 = atomic_load_explicit(&sc->vpts_seq, memory_order_acquire);
+
+        if (seq1 == 0)
+            return false;  // never committed
+
+        if (seq1 & 1)
+            continue;  // write in progress — spin
+
+        int64_t st      = atomic_load_explicit(&sc->vpts_server_us, memory_order_relaxed);
+        int64_t pts     = atomic_load_explicit(&sc->vpts_pts_us,    memory_order_relaxed);
+        int32_t paused  = atomic_load_explicit(&sc->vpts_paused,    memory_order_relaxed);
+
+        // Acquire fence then re-read seq to detect concurrent write.
+        atomic_thread_fence(memory_order_acquire);
+        uint64_t seq2 = atomic_load_explicit(&sc->vpts_seq, memory_order_relaxed);
+
+        if (seq1 != seq2)
+            continue;  // writer updated during our read — retry
+
+        *out_ntp_time = (double)st  / 1000000.0;
+        *out_video_pts   = (double)pts / 1000000.0;
+        *out_is_paused   = (bool)paused;
+        return true;
+    }
+}
+
diff --git a/player/server_sync.h b/player/server_sync.h
new file mode 100644
index 0000000000..77f657f628
--- /dev/null
+++ b/player/server_sync.h
@@ -0,0 +1,135 @@
+#ifndef MP_SERVER_SYNC_H
+#define MP_SERVER_SYNC_H
+
+#include <stdatomic.h>
+#include <stdbool.h>
+#include <stdint.h>
+#include "osdep/timer.h"
+#include "common/common.h"
+
+// PID 控制器 + 平滑滤波器
+// 2.1 核心思路
+// 用一个增量式 PID 控制器代替分段线性查表：
+
+
+// ┌──────────────────────────┐
+//                     │  P项: 比例 (即时纠正)    │
+//  diff (误差) ──────▶│  I项: 积分 (消除稳态误差)│──▶ speed_shift ──▶ 低通滤波器 ──▶ 最终速度
+//                     │  D项: 微分 (预测趋势)    │
+//                     └──────────────────────────┘
+// P 项：按误差大小比例输出速度偏移，处理即时误差
+// I 项：累积误差，消除服务器时钟频率漂移导致的稳态误差
+// D 项（可选）：检测误差变化趋势，防止过冲
+// 低通滤波器：对输出速度做平滑，防止速度频繁切换造成音频颤音
+// 2.2 具体参数（针对你的场景）
+// 你的场景特点：
+
+// 通常只有视频，无音频
+// 服务器时钟有漂移（飘逸），50ms 以内不干预
+// 需要快速追上大误差
+// 对应的 PID 参数策略：
+
+// Kp（比例系数）：大误差时主导，小误差时次要
+// Ki（积分系数）：非常小，只用于消除服务器时钟漂移
+// Kd：可选，避免过冲时使用
+// 低通滤波器 α：平滑速度输出，防止颤音
+
+// 指标            现有方案（分段线性 P）    改进方案（PID + 低通）
+// 小误差(<50ms)      不干预 ✓                  不干预 ✓
+// 50-100ms 追赶      线性变速，有振荡风险       低 Kp PID，平滑收敛
+// 100-200ms 追赶     斜率突变，速度阶跃         中 Kp PID，无阶跃
+// 200ms+ 追赶        较快，但超调后会振荡       大 Kp + D 防超调
+// 服务器时钟漂移      无法消除 ✗                I 项自动补偿 ✓
+// 音频颤音           高风险（速度帧帧跳变）✗    低通滤波器消除 ✓
+
+struct mp_ntp_clock {
+    // NTP synchronization state
+    atomic_bool clock_valid;
+    atomic_int_least64_t local_time_ns;
+    atomic_int_least64_t ntp_time_us;
+
+    // Server playback state — protected by a seqlock (tc_gen).
+    // Writer increments tc_gen to odd before writing, then to even after.
+    // Reader retries if tc_gen is odd or changes between two reads.
+    atomic_uint_least32_t tc_gen;       // seqlock generation (odd = writing)
+    atomic_bool timecode_valid;
+
+    // Payload written under the seqlock
+    atomic_int_least64_t tc_ntp_time_us;
+    atomic_int_least64_t tc_timecode_us;
+    atomic_bool tc_paused;
+
+    // Statistics
+    atomic_bool stat_is_correcting;
+    atomic_uint_least64_t stat_frames_total;
+    atomic_uint_least64_t stat_frames_diff_17;
+    atomic_uint_least64_t stat_frames_diff_35;
+    atomic_uint_least64_t stat_frames_diff_50;
+    atomic_uint_least64_t stat_frames_diff_68;
+
+    // Committed video PTS sync point (seqlock: odd = writing, even = done, 0 = never set)
+    // Guarantees that (vpts_server_us, vpts_pts_us, vpts_paused) are always a consistent
+    // snapshot: "at server time X, video was at position Y and pause state was Z"
+    atomic_uint_least64_t vpts_seq;        // seqlock generation counter
+    atomic_int_least64_t  vpts_server_us;  // server time when snapshot was taken (microseconds)
+    atomic_int_least64_t  vpts_pts_us;     // video_pts at that server time (microseconds)
+    atomic_int_least32_t  vpts_paused;     // paused state at snapshot time (0 or 1)
+
+    // ── PID controller state ────────────────────────────────────────────────
+    // These fields are ONLY accessed from the playback thread (write_video /
+    // update_avsync_before_frame), so plain double/bool — no atomics needed.
+    double pid_integral;      // I-term accumulator
+    double pid_last_diff;     // previous error (for D-term)
+    double pid_last_speed;    // last output speed (for low-pass filter)
+    bool   pid_is_correcting; // explicit correction state (avoids float compare)
+};
+
+// Initializes the server clock to an invalid/zero state
+void mp_ntp_clock_init(struct mp_ntp_clock *sc);
+
+// Set the NTP synchronization point
+void mp_ntp_clock_set_time(struct mp_ntp_clock *sc, double ntp_time);
+
+// Get the current computed server time based on local elapsed time
+double mp_ntp_clock_get_ntp_time(struct mp_ntp_clock *sc);
+
+// Set the server's playback timecode and paused state (seqlock-protected write)
+void mp_ntp_clock_set_timecode(struct mp_ntp_clock *sc, double ntp_time, double timecode, bool paused);
+
+// Get the expected timecode of the media exactly right now
+double mp_ntp_clock_get_target_timecode(struct mp_ntp_clock *sc);
+
+// Check if the server is paused
+bool mp_ntp_clock_is_paused(struct mp_ntp_clock *sc);
+
+// Record sync offset statistics
+void mp_ntp_clock_add_stat(struct mp_ntp_clock *sc, double abs_diff, bool is_correcting);
+
+// Reset PID state after a seek or playback restart.
+// Must be called from the playback thread.
+void mp_ntp_clock_reset_pid(struct mp_ntp_clock *sc);
+
+// Full reset of all runtime state: NTP validity, timecode validity, statistics,
+// PID controller, and vpts snapshot.  Call this when a new file starts playing
+// so that stale clock data from the previous file cannot affect the new one.
+// Safe to call from the playback thread.
+void mp_ntp_clock_reset(struct mp_ntp_clock *sc);
+
+// Commit an atomic (ntp_time, video_pts, is_paused) snapshot.
+// Call this whenever video_pts or pause state changes (from the playback thread).
+// Lock-free using a seqlock — safe to call from the playback thread.
+void mp_ntp_clock_commit_video_pts(struct mp_ntp_clock *sc,
+                                       double ntp_time, double video_pts,
+                                       bool is_paused);
+
+// Read the last committed snapshot.
+// Returns true if a valid snapshot exists, false if none has been committed yet.
+// The returned triple is guaranteed to be internally consistent:
+// at ntp_time X, video was exactly at video_pts Y with pause state Z.
+// Lock-free using a seqlock — safe to call from any thread.
+bool mp_ntp_clock_get_video_pts(struct mp_ntp_clock *sc,
+                                    double *out_ntp_time,
+                                    double *out_video_pts,
+                                    bool   *out_is_paused);
+
+#endif
diff --git a/player/video.c b/player/video.c
index 820bbfbf6c..14e7402a98 100644
--- a/player/video.c
+++ b/player/video.c
@@ -1249,6 +1249,21 @@ void write_video(struct MPContext *mpctx)
     mpctx->last_frame_duration =
         mpctx->next_frames[0]->pkt_duration / mpctx->video_speed;
 
+    // Commit an atomic (ntp_time, video_pts, is_paused) snapshot for external query.
+    // We capture server time at exactly the same moment video_pts is updated,
+    // guaranteeing the triple is perfectly consistent.
+    if (atomic_load_explicit(&mpctx->ntp_clock.clock_valid,
+                             memory_order_relaxed))
+    {
+        double sv_time = mp_ntp_clock_get_ntp_time(&mpctx->ntp_clock);
+        // mpctx->playback_pts (get_current_time) lags by 1 frame here because
+        // handle_playback_time runs after write_video. Since we are in write_video,
+        // video_pts is exactly what playback_pts will become.
+        mp_ntp_clock_commit_video_pts(&mpctx->ntp_clock,
+                                         sv_time, mpctx->video_pts,
+                                         mpctx->paused);
+    }
+
     shift_frames(mpctx);
 
     schedule_frame(mpctx, frame);

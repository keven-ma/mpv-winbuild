+void mpv_ntp_clock_sync(mpv_handle *ctx, double ntp_time)
+{
+    mp_ntp_clock_set_time(&ctx->mpctx->ntp_clock, ntp_time);
+    mp_wakeup_core(ctx->mpctx);
+}
+
+void mpv_ntp_timecode_set(mpv_handle *ctx, double ntp_time,
+                              double timecode, int paused)
+{
+    mp_ntp_clock_set_timecode(&ctx->mpctx->ntp_clock,
+                                 ntp_time, timecode, paused);
+    mp_wakeup_core(ctx->mpctx);
+}
+
+double mpv_ntp_clock_get(mpv_handle *ctx)
+{
+    return mp_ntp_clock_get_ntp_time(&ctx->mpctx->ntp_clock);
+}
+
+int mpv_get_video_sync_point(mpv_handle *ctx,
+                              double *out_ntp_time,
+                              double *out_video_pts,
+                              int    *out_is_paused)
+{
+    bool paused;
+    bool ok = mp_ntp_clock_get_video_pts(&ctx->mpctx->ntp_clock,
+                                             out_ntp_time,
+                                             out_video_pts,
+                                             &paused);
+    if (ok)
+        *out_is_paused = paused ? 1 : 0;
+    return ok ? 0 : -1;
+}
+
 #include "video/out/libmpv.h"
 

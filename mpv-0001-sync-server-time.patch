@@ -4601,6 +4601,68 @@ static int mp_property_clipboard(void *ctx, struct m_property *prop,
 #define M_PROPERTY_DEPRECATED_ALIAS(name, real_property) \
     {(name), mp_property_deprecated_alias, .priv = (real_property)}
 
+
+// Returns a NODE_MAP with all sync statistics in a single atomic snapshot:
+//   "is-correcting"   (flag)  – whether speed correction is currently active
+//   "frames-total"    (int64) – total frames evaluated
+//   "frames-diff-17"  (int64) – frames with |diff| < 17 ms  (~1 frame @60fps)
+//   "frames-diff-35"  (int64) – frames with |diff| < 35 ms  (~2 frames @60fps)
+//   "frames-diff-50"  (int64) – frames with |diff| < 50 ms
+//   "frames-diff-68"  (int64) – frames with |diff| < 68 ms  (~4 frames @60fps)
+static int mp_property_ntp_sync_stats(void *ctx, struct m_property *prop,
+                                          int action, void *arg)
+{
+    struct MPContext *mpctx = ctx;
+    if (action == M_PROPERTY_GET_TYPE) {
+        *(struct m_option *)arg = (struct m_option){.type = CONF_TYPE_NODE};
+        return M_PROPERTY_OK;
+    }
+    if (action != M_PROPERTY_GET)
+        return M_PROPERTY_NOT_IMPLEMENTED;
+
+    struct mp_ntp_clock *sc = &mpctx->ntp_clock;
+    struct mpv_node node = {0};
+    node_init(&node, MPV_FORMAT_NODE_MAP, NULL);
+    node_map_add_flag (&node, "is-correcting",  atomic_load(&sc->stat_is_correcting));
+    node_map_add_int64(&node, "frames-total",   atomic_load(&sc->stat_frames_total));
+    node_map_add_int64(&node, "frames-diff-17", atomic_load(&sc->stat_frames_diff_17));
+    node_map_add_int64(&node, "frames-diff-35", atomic_load(&sc->stat_frames_diff_35));
+    node_map_add_int64(&node, "frames-diff-50", atomic_load(&sc->stat_frames_diff_50));
+    node_map_add_int64(&node, "frames-diff-68", atomic_load(&sc->stat_frames_diff_68));
+    *(struct mpv_node *)arg = node;
+    return M_PROPERTY_OK;
+}
+
+// Returns a NODE_MAP with keys "ntp-time", "video-pts", and "is-paused".
+// All three values come from the same atomic seqlock snapshot — they are
+// guaranteed to be internally consistent:
+//   at ntp-time X, video was at video-pts Y with pause state Z.
+// This is the primary API for master/slave synchronization via Node.js IPC.
+static int mp_property_ntp_sync_pos(void *ctx, struct m_property *prop,
+                                         int action, void *arg)
+{
+    struct MPContext *mpctx = ctx;
+    if (action == M_PROPERTY_GET_TYPE) {
+        *(struct m_option *)arg = (struct m_option){.type = CONF_TYPE_NODE};
+        return M_PROPERTY_OK;
+    }
+    if (action != M_PROPERTY_GET)
+        return M_PROPERTY_NOT_IMPLEMENTED;
+
+    double ntp_time, video_pts;
+    bool is_paused;
+    if (!mp_ntp_clock_get_video_pts(&mpctx->ntp_clock, &ntp_time, &video_pts, &is_paused))
+        return M_PROPERTY_UNAVAILABLE;
+
+    struct mpv_node node = {0};
+    node_init(&node, MPV_FORMAT_NODE_MAP, NULL);
+    node_map_add_double(&node, "ntp-time",    ntp_time * 1000.0);
+    node_map_add_double(&node, "video-pts",   video_pts);
+    node_map_add_flag(&node,   "is-paused",   is_paused);
+    *(struct mpv_node *)arg = node;
+    return M_PROPERTY_OK;
+}
+
 // Base list of properties. This does not include option-mapped properties.
 static const struct m_property mp_properties_base[] = {
     // General
@@ -4641,6 +4703,8 @@ static const struct m_property mp_properties_base[] = {
     {"remaining-ab-loops", mp_property_remaining_ab_loops},

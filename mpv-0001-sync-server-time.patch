diff --git a/include/mpv/client.h b/include/mpv/client.h
index f72a0e0a46..d0b17ccc91 100644
--- a/include/mpv/client.h
+++ b/include/mpv/client.h
@@ -622,6 +622,92 @@ MPV_EXPORT int64_t mpv_get_time_ns(mpv_handle *ctx);
  */
 MPV_EXPORT int64_t mpv_get_time_us(mpv_handle *ctx);
 
+/**
+ * Server-synchronized playback (timecode sync) API.
+ *
+ * These functions allow synchronizing mpv playback to a remote server's
+ * timeline. They are designed to be called from any thread with minimal
+ * overhead (lock-free atomic operations internally).
+ *
+ * Usage flow:
+ * 1. Set video-sync=timecode option before or during playback
+ * 2. Call mpv_server_clock_sync() to establish NTP-like time correlation
+ * 3. Call mpv_server_timecode_set() to provide server playback state
+ * 4. mpv will automatically align video/audio to the server timecode
+ */
+
+/**
+ * Set the NTP synchronization point. This correlates the local monotonic
+ * clock with the server's time. Call this periodically (e.g. every few
+ * seconds) to maintain accurate time correlation.
+ *
+ * @param server_time The current server time in seconds (e.g. Unix epoch).
+ *                    The absolute value doesn't matter as long as it's
+ *                    consistent with values passed to mpv_server_timecode_set().
+ *
+ * Safe to be called from any thread. Lock-free.
+ */
+MPV_EXPORT void mpv_server_clock_sync(mpv_handle *ctx, double server_time);
+
+/**
+ * Set the server's current playback state. This tells mpv what media
+ * timecode the server is at (or was at) at a given server time.
+ *
+ * @param server_time The server time when this timecode was sampled.
+ *                    Must be in the same time base as mpv_server_clock_sync().
+ * @param timecode    The media timecode (playback position) at server_time,
+ *                    in seconds.
+ * @param paused      Whether the server is currently paused.
+ *
+ * Safe to be called from any thread. Lock-free.
+ */
+MPV_EXPORT void mpv_server_timecode_set(mpv_handle *ctx,
+                                         double server_time,
+                                         double timecode,
+                                         int paused);
+
+/**
+ * Get the current computed server time based on the last sync point and
+ * local clock elapsed time.
+ *
+ * @return The current server time in seconds, or a negative value if
+ *         no sync point has been set yet.
+ *
+ * Safe to be called from any thread. Lock-free.
+ */
+MPV_EXPORT double mpv_server_clock_get(mpv_handle *ctx);
+
+/**
+ * Get the last committed video frame position paired with the server time at
+ * which it was captured.  This triple is guaranteed to be perfectly consistent:
+ * at server time *out_server_time, the client's video was at *out_video_pts
+ * and the pause state was *out_is_paused.
+ *
+ * The value may be up to one video frame behind the actual current position,
+ * but the three output values always correspond to the same instant — they are
+ * written atomically inside the playback thread via a seqlock.
+ *
+ * Typical use on a master node: call mpv_server_clock_sync() periodically,
+ * then poll this function and broadcast the result to slave players so they
+ * can call mpv_server_timecode_set() to synchronize.
+ *
+ * @param out_server_time  Set to the server time (seconds) of the snapshot.
+ *                         Must not be NULL.
+ * @param out_video_pts    Set to the video position (seconds) at that time.
+ *                         Must not be NULL.
+ * @param out_is_paused    Set to non-zero if the player was paused at snapshot
+ *                         time.  Must not be NULL.
+ * @return 0 on success; -1 if no snapshot is available yet (call
+ *         mpv_server_clock_sync() first to establish the time base).
+ *
+ * Safe to be called from any thread. Lock-free.
+ */
+MPV_EXPORT int mpv_get_video_sync_point(mpv_handle *ctx,
+                                         double *out_server_time,
+                                         double *out_video_pts,
+                                         int    *out_is_paused);
+
+
 /**
  * Data format for options and properties. The API functions to get/set
  * properties and options support multiple formats, and this enum describes

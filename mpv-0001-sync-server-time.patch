       "secondary-sub-end", "sub-lines", "secondary-sub-lines", "video-out-params",
-      "video-dec-params", "video-params", "deinterlace-active", "video-target-params"),
+      "video-dec-params", "video-params",
+      "deinterlace-active", "video-target-params", "ntp-sync-pos"),
     E(MP_EVENT_DURATION_UPDATE, "duration"),
     E(MPV_EVENT_VIDEO_RECONFIG, "video-out-params", "video-params",
       "video-format", "video-codec", "video-bitrate", "dwidth", "dheight",
@@ -7447,12 +7512,44 @@ static void cmd_notify_property(void *p)
  * Lua with mp.command_native().
